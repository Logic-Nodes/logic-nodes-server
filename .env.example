NODE_ENV=development
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logicnodesdb
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# IoT ingestion (ESP32 over HTTPS)
IOT_OFFLINE_AFTER_SECONDS=90
IOT_MONITOR_INTERVAL_SECONDS=30
IOT_MIN_TEMPERATURE=2
IOT_MAX_TEMPERATURE=8
IOT_MIN_HUMIDITY=20
IOT_MAX_HUMIDITY=85
IOT_MAX_VIBRATION=5
CORS_ORIGINS=http://localhost:4200,https://logic-nodes-webapp.vercel.app

# Background jobs
ENABLE_BACKGROUND_JOBS=true
IOT_DISCONNECT_MINUTES=15
IOT_JOB_INTERVAL_MINUTES=5
RENEWAL_JOB_INTERVAL_MINUTES=720
SUBSCRIPTION_NOTICE_DAYS=7

# Demo seed credentials
DEMO_SEED_EMAIL=demo.mobile.2026@omnitrack.io
DEMO_SEED_PASSWORD=DemoMobile123!

# Optional integrations
MQTT_BROKER_URL=
MQTT_TELEMETRY_TOPIC=omnitrack/telemetry/#
MQTT_USERNAME=
MQTT_PASSWORD=
STRIPE_SECRET_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
# Alternativa en Render (JSON minificado en una línea):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
